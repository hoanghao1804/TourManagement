                                    <li><a class="dropdown-item" asp-area="" asp-controller="ThongBao" asp-action="Index"><i class="fas fa-bell"></i> Thông báo</a></li>
                                    <li><a class="dropdown-item" asp-controller="Home" asp-action="MyFavorites"><i class="fas fa-heart"></i> Danh sách yêu thích</a></li>
