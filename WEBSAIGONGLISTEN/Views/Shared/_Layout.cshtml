                        else
                        {
                            <div class="auth-buttons">
                                <a class="btn-login" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
                                <a class="btn-register" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
        
        <!-- Google Translate Script -->
        <script type="text/javascript">
            function changeLanguage(langCode) {
                console.log('Changing language to:', langCode);
                
                // Ẩn dropdown
                var dropdown = bootstrap.Dropdown.getInstance(document.querySelector('.language-toggle'));
                if (dropdown) {
                    dropdown.hide();
                }
                
                // Tạo URL với hash
                var currentUrl = window.location.origin + window.location.pathname;
                var newUrl = currentUrl + '#googtrans(vi|' + langCode + ')';
                
                // Thay đổi hash trước
                window.location.hash = 'googtrans(vi|' + langCode + ')';
                
                // Sau đó reload trang
                setTimeout(function() {
                    window.location.reload();
                }, 100);
            }

            function googleTranslateElementInit() {
                new google.translate.TranslateElement({
                    pageLanguage: 'vi',
                    includedLanguages: 'en,fr,de,es,zh-CN,ja,ko,vi',
                    layout: google.translate.TranslateElement.InlineLayout.SIMPLE
                }, 'google_translate_element');
                
                console.log('Google Translate initialized');
                
                // Ẩn Google Translate widget mặc định
                setTimeout(function() {
                    var translateElement = document.querySelector('#google_translate_element');
                    if (translateElement) {
                        translateElement.style.display = 'none';
                    }
                }, 100);
            }
        </script>
        <script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    </header>

