@model List<WEBSAIGONGLISTEN.Models.Booking>

@{
    ViewData["Title"] = "Lịch sử đặt tour";
}

<link rel="stylesheet" href="~/css/booking-history.css" />

<!-- Hero Section -->
<div class="booking-hero">
    <div class="container">
        <div class="hero-content">
            <h1><i class="fas fa-history"></i>Lịch sử đặt tour</h1>
            <p>Xem lại các tour bạn đã đặt và quản lý đặt chỗ của mình</p>
        </div>
    </div>
</div>

<div class="booking-container">
    <div class="container">

        @if (Model != null && Model.Count > 0)
        {
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                </div>
            }

            <!-- Booking Cards -->
            <div class="booking-cards">
                @foreach (var item in Model)
                {
                    <div class="booking-card">
                        <div class="booking-header">
                            <div class="tour-info">
                                <h3>@item.Product?.Name</h3>
                                <div class="booking-meta">
                                    <p class="booking-id">Mã đặt tour: #@item.Id</p>
                                    <div class="booking-date">
                                        <i class="fas fa-calendar-alt"></i>
                                        <span>@item.BookingDate.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="booking-status">
                                @if (item.Status == "Pending")
                                {
                                    <span class="status-badge status-pending">
                                        <i class="fas fa-clock"></i>Chờ xử lý
                                    </span>
                                }
                                else if (item.Status == "Canceled")
                                {
                                    <span class="status-badge status-canceled">
                                        <i class="fas fa-times-circle"></i>Đã hủy
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-completed">
                                        <i class="fas fa-check-circle"></i>Hoàn thành
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="booking-details">
                            <div class="detail-row">
                               
                                <div class="detail-item">
                                    <i class="fas fa-user"></i>
                                    <span class="label">Người đặt:</span>
                                    <span class="value">@(item.ApplicationUser?.Email ?? "Khách")</span>
                                </div>
                            </div>

                            <div class="passenger-details">
                                <h4><i class="fas fa-users"></i>Thông tin khách</h4>
                                <div class="passenger-grid">
                                    <div class="passenger-item">
                                        <span class="passenger-type">Trẻ nhỏ (&lt; 2 tuổi)</span>
                                        <span class="passenger-count">@item.QuantityUnder2 người</span>
                                    </div>
                                    <div class="passenger-item">
                                        <span class="passenger-type">Trẻ em (2-10 tuổi)</span>
                                        <span class="passenger-count">@item.Quantity2To10 người</span>
                                    </div>
                                    <div class="passenger-item">
                                        <span class="passenger-type">Người lớn (> 10 tuổi)</span>
                                        <span class="passenger-count">@item.QuantityAbove10 người</span>
                                    </div>
                                </div>
                            </div>

                            <div class="booking-footer">
                                <div class="total-price">
                                    <span class="price-label">Tổng giá trị:</span>
                                    <span class="price-value">@item.TotalPrice.ToString("N0") ₫</span>
                                </div>
                                <div class="booking-actions">
                                    @if (item.Status == "Pending")
                                    {
                                        <button class="btn-cancel" data-bs-toggle="modal" data-bs-target="#cancelModal"
                                                data-id="@item.Id" data-tour="@item.Product?.Name">
                                            <i class="fas fa-times"></i> Hủy tour
                                        </button>
                                    }
                                    else if (item.Status == "Canceled")
                                    {
                                        <span class="text-muted">
                                            <i class="fas fa-ban"></i>Đã hủy
                                        </span>
                                    }
                                    else
                                    {
                                        <button class="btn-view-details">
                                            <i class="fas fa-eye"></i>Xem chi tiết
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Modal for Cancel Booking -->
            <div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <form method="post" action="/Booking/CancelBooking">
                            <div class="modal-header">
                                <h5 class="modal-title" id="cancelModalLabel">
                                    <i class="fas fa-exclamation-triangle me-2"></i>Hủy đặt tour
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="alert alert-warning">
                                    <i class="fas fa-info-circle me-2"></i>
                                    Bạn có chắc chắn muốn hủy tour <strong id="tourName"></strong>?
                                </div>
                                <input type="hidden" name="id" id="cancelBookingId" />
                                <div class="mb-3">
                                    <label for="cancellationReason" class="form-label">
                                        <i class="fas fa-comment me-1"></i>Lý do hủy:
                                    </label>
                                    <textarea class="form-control" name="cancellationReason" id="cancellationReason" 
                                              rows="4" placeholder="Vui lòng nhập lý do hủy tour..." required></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                    <i class="fas fa-times me-1"></i>Đóng
                                </button>
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-check me-1"></i>Xác nhận hủy
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-calendar-times"></i>
                </div>
                <h3>Chưa có lịch sử đặt tour</h3>
                <p>Bạn chưa có tour nào được đặt. Hãy khám phá các tour du lịch hấp dẫn!</p>
                <a href="/Home" class="btn btn-primary">
                    <i class="fas fa-search me-2"></i>Khám phá tour
                </a>
            </div>
        }
    </div>
</div>

    <script>
        var cancelModal = document.getElementById('cancelModal');
        cancelModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var bookingId = button.getAttribute('data-id');
            var tourName = button.getAttribute('data-tour');
            var inputId = cancelModal.querySelector('#cancelBookingId');
            var tourNameElement = cancelModal.querySelector('#tourName');

            inputId.value = bookingId;
            tourNameElement.textContent = tourName;
        });
    </script>
