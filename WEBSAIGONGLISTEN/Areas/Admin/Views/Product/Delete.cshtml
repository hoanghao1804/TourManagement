@model WEBSAIGONGLISTEN.Models.Product
@{
    ViewData["Title"] = "Xóa gói du lịch";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var tourDays = ViewBag.TourDays as List<WEBSAIGONGLISTEN.Models.TourDay>;
    var hasTourDays = ViewBag.HasTourDays as bool? ?? false;
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card mt-4">
                <div class="card-header bg-danger text-white">
                    <h3 class="card-title mb-0">@ViewData["Title"]</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h5><i class="fas fa-exclamation-triangle"></i> Cảnh báo</h5>
                        <p>Bạn có chắc chắn muốn xóa gói du lịch <strong>@Model.Name</strong>?</p>
                    </div>

                    @if (hasTourDays)
                    {
                        <div class="alert alert-warning">
                            <h6><i class="fas fa-exclamation-triangle"></i> Cảnh báo quan trọng</h6>
                            <p>Gói du lịch <strong>@Model.Name</strong> có <strong>@tourDays.Count</strong> ngày tour liên quan sẽ bị xóa cùng:</p>
                            <ul class="mb-3">
                                @foreach (var tourDay in tourDays)
                                {
                                    <li><strong>Ngày @tourDay.DayNumber:</strong> @tourDay.Description</li>
                                }
                            </ul>
                            <p class="mb-0"><strong>⚠️ Hành động này không thể hoàn tác!</strong></p>
                        </div>

                        <form asp-action="DeleteConfirmed" method="post" class="text-center">
                            <input type="hidden" asp-for="Id" />
                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="confirmDelete" required>
                                    <label class="form-check-label" for="confirmDelete">
                                        <strong>Tôi hiểu rằng việc xóa này sẽ xóa cả @tourDays.Count ngày tour liên quan và không thể hoàn tác</strong>
                                    </label>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-danger me-2" id="deleteButton" disabled>
                                <i class="fas fa-trash"></i> Tôi muốn xóa hết
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Hủy bỏ
                            </a>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success">
                            <h6><i class="fas fa-check-circle"></i> An toàn để xóa</h6>
                            <p>Gói du lịch này không có ngày tour liên quan và có thể được xóa an toàn.</p>
                        </div>

                        <form asp-action="DeleteConfirmed" method="post" class="text-center">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn btn-danger me-2">
                                <i class="fas fa-trash"></i> Xóa gói du lịch
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Hủy bỏ
                            </a>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const confirmCheckbox = document.getElementById('confirmDelete');
            const deleteButton = document.getElementById('deleteButton');
            
            if (confirmCheckbox && deleteButton) {
                confirmCheckbox.addEventListener('change', function() {
                    deleteButton.disabled = !this.checked;
                });
            }
        });
    </script>
}
