@model IEnumerable<WEBSAIGONGLISTEN.Models.Product>
@{
    ViewData["Title"] = "Danh sách gói du lịch";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Filter Section -->
<div class="card mb-4 shadow">
    <div class="card-body">
        <form id="filterForm">
            <div class="row g-2">
                <!-- Tìm kiếm theo tên -->
                <div class="col-md-3">
                    <label for="searchName" class="form-label fw-bold">
                        <i class="fas fa-search me-1"></i>
                        Tìm kiếm theo tên
                    </label>
                    <input type="text" 
                           class="form-control" 
                           id="searchName" 
                           name="searchName" 
                           value="@(ViewBag.SearchName ?? "")"
                           placeholder="Nhập tên sản phẩm...">
                </div>

                <!-- Filter theo khu vực -->
                <div class="col-md-2">
                    <label for="categoryFilter" class="form-label fw-bold">
                        <i class="fas fa-map-marker-alt me-1"></i>
                        Khu vực
                    </label>
                    <select class="form-select" id="categoryFilter" name="categoryId">
                        <option value="">Tất cả khu vực</option>
                        @if (ViewBag.Categories != null)
                        {
                            @foreach (var category in ViewBag.Categories)
                            {
                                var isSelected = ViewBag.SelectedCategoryId?.ToString() == category.Id.ToString() ? "selected" : "";
                                <option value="@category.Id" selected="@isSelected">
                                    @category.Name
                                </option>
                            }
                        }
                        else
                        {
                            <option value="1">Du lịch miền Bắc</option>
                            <option value="2">Du lịch miền Trung</option>
                            <option value="3">Du lịch miền Nam</option>
                            <option value="4">Du lịch nước ngoài</option>
                        }
                    </select>
                </div>

                <!-- Filter theo ngày bắt đầu -->
                <div class="col-md-2">
                    <label for="fromDate" class="form-label fw-bold">
                        <i class="fas fa-calendar-alt me-1"></i>
                        Từ ngày
                    </label>
                    <input type="date" 
                           class="form-control" 
                           id="fromDate" 
                           name="fromDate" 
                           value="@(ViewBag.FromDate ?? "")">
                </div>

                <!-- Filter theo ngày kết thúc -->
                <div class="col-md-2">
                    <label for="toDate" class="form-label fw-bold">
                        <i class="fas fa-calendar-alt me-1"></i>
                        Đến ngày
                    </label>
                    <input type="date" 
                           class="form-control" 
                           id="toDate" 
                           name="toDate" 
                           value="@(ViewBag.ToDate ?? "")">
                </div>

                <!-- Nút tìm kiếm -->
                <div class="col-md-2 d-flex align-items-end">
                    <button type="button" id="searchBtn" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i>
                        Tìm kiếm
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Action Buttons -->
<div class="mb-3 d-flex justify-content-between align-items-center">
    <div>
        <a asp-action="Add" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>
            Thêm sản phẩm mới
        </a>
    </div>
    <div class="text-muted">
        <i class="fas fa-info-circle me-1"></i>
        Tìm thấy <strong>@Model.Count()</strong> sản phẩm
    </div>
</div>

<div id="productTableContainer">
    <div class="table-responsive mb-5">
        <table class="table table-bordered table-striped">
            <thead class="thead-dark">
                <tr>
                    <th>Tên</th>
                    <th>Khu vực</th>
                    <th>Số ngày/đêm</th>
                    <th>Ngày khởi hành</th>
                    <th>Ngày kết thúc</th>
                    <th>Hình ảnh</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td>@product.Category?.Name</td>
                        <td>@product.DaysNightsDescription</td>
                        <td>@product.StartDate.ToString("dd/MM/yyyy")</td>
                        <td>@product.EndDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            <img src="@product.ImageUrl" alt="Product Image" style="max-width: 80px;" data-bs-toggle="tooltip" title="Xem ảnh lớn">
                        </td>
                        <td>
                            <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-info btn-sm">Xem</a>
                            <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Phân trang -->
@if (ViewData["CurrentPage"] != null && ViewData["TotalPages"] != null)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @{
                int currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
                int totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
            }

            <!-- Nút Previous -->
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = currentPage - 1 })" aria-label="Previous">
                    &laquo;
                </a>
            </li>

            <!-- Các trang -->
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                </li>
            }

            <!-- Nút Next -->
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = currentPage + 1 })" aria-label="Next">
                    &raquo;
                </a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        // Kích hoạt tooltip của Bootstrap
        document.addEventListener("DOMContentLoaded", function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })

            // AJAX search function
            function performSearch() {
                const searchName = document.getElementById('searchName').value;
                const categoryId = document.getElementById('categoryFilter').value;
                const fromDate = document.getElementById('fromDate').value;
                const toDate = document.getElementById('toDate').value;

                const params = new URLSearchParams();
                if (searchName) params.append('searchName', searchName);
                if (categoryId) params.append('categoryId', categoryId);
                if (fromDate) params.append('fromDate', fromDate);
                if (toDate) params.append('toDate', toDate);

                // Show loading
                document.getElementById('productTableContainer').innerHTML = '<div class="text-center p-4"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';

                fetch('@Url.Action("Index")?' + params.toString())
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.text();
                    })
                    .then(html => {
                        // Parse the response to extract only the table content
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const tableContainer = doc.querySelector('#productTableContainer');
                        
                        if (tableContainer) {
                            document.getElementById('productTableContainer').innerHTML = tableContainer.innerHTML;
                            
                            // Re-initialize tooltips
                            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
                            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                                return new bootstrap.Tooltip(tooltipTriggerEl)
                            });
                        } else {
                            document.getElementById('productTableContainer').innerHTML = '<div class="alert alert-warning">Không tìm thấy kết quả nào</div>';
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        document.getElementById('productTableContainer').innerHTML = '<div class="alert alert-danger">Có lỗi xảy ra khi tìm kiếm</div>';
                    });
            }

            // Search button click
            document.getElementById('searchBtn').addEventListener('click', performSearch);

            // Auto-search when select changes
            document.getElementById('categoryFilter').addEventListener('change', performSearch);

            // Auto-search when date changes
            document.getElementById('fromDate').addEventListener('change', performSearch);
            document.getElementById('toDate').addEventListener('change', performSearch);

            // Search with Enter key
            document.getElementById('searchName').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    performSearch();
                }
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
