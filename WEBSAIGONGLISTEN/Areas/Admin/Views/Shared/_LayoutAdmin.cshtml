        // Initialize search forms
        function initializeSearchForms() {
            // Re-attach search form event listeners
            const searchForms = document.querySelectorAll('form[action*="Search"], form[onsubmit*="validateSearchForm"]');
            searchForms.forEach(form => {
                // Remove existing event listeners
                form.removeEventListener('submit', handleSearchSubmit);
                // Add new event listener
                form.addEventListener('submit', handleSearchSubmit);
            });
            
            // Re-attach search input event listeners
            const searchInputs = document.querySelectorAll('input[type="search"], input[name*="search"], input[id*="search"]');
            searchInputs.forEach(input => {
                // Remove existing event listeners
                input.removeEventListener('keyup', handleSearchInput);
                input.removeEventListener('change', handleSearchInput);
                // Add new event listeners
                input.addEventListener('keyup', handleSearchInput);
                input.addEventListener('change', handleSearchInput);
            });
        }
        
        // Handle search form submission
        function handleSearchSubmit(event) {
            const form = event.target;
            const searchInput = form.querySelector('input[type="search"], input[name*="search"], input[id*="search"]');
            
            if (searchInput && searchInput.value.trim() === '') {
                event.preventDefault();
                alert('Vui lòng nhập từ khóa tìm kiếm');
                return false;
            }
            
            // If it's a search form, use AJAX to load results
            if (form.action && form.action.includes('Search')) {
                event.preventDefault();
                const formData = new FormData(form);
                const url = new URL(form.action, window.location.origin);
                
                // Add form data to URL
                for (let [key, value] of formData.entries()) {
                    url.searchParams.append(key, value);
                }
                
                // Load search results via AJAX
                loadPage(url.toString(), 'Kết quả tìm kiếm');
                return false;
            }
        }
        
        // Handle search input changes
        function handleSearchInput(event) {
            const input = event.target;
            const form = input.closest('form');
            
            // Auto-submit search form after 1 second of no typing
            clearTimeout(input.searchTimeout);
            input.searchTimeout = setTimeout(() => {
                if (form && form.action && form.action.includes('Search')) {
                    form.dispatchEvent(new Event('submit'));
                }
            }, 1000);
        }
        
        // Initialize data tables
        function initializeDataTables() {
            // Re-initialize any data table functionality
            const tables = document.querySelectorAll('table[data-search], table[data-filter]');
            tables.forEach(table => {
