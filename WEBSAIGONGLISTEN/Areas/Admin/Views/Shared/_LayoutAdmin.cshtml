        }
        
        // Remove animations from all header elements
        const headerElements = document.querySelectorAll('.navbar, .navbar *, .navbar-brand-wrapper, .navbar-brand-wrapper *, .navbar-menu-wrapper, .navbar-menu-wrapper *, .navbar-nav, .navbar-nav *, .navbar-toggler, .navbar-toggler *, .dropdown-menu, .dropdown-menu *, .navbar-dropdown, .navbar-dropdown *');
        headerElements.forEach(element => {
