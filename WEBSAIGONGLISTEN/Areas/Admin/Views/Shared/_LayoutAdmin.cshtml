            </nav>


            <div class="main-panel">
                <div class="content-wrapper">
                    @RenderBody()
                </div>

                <footer class="footer">
                    <div class="container-fluid d-flex justify-content-between">
                        <span class="text-muted d-block text-center text-sm-start d-sm-inline-block"> &copy; 2024 - SAIGON GLISTEN - Đồ án môn học</span>
                       @*  <span class="float-none float-sm-end mt-1 mt-sm-0 text-end"> Free <a href="https://www.bootstrapdash.com/bootstrap-admin-template/" target="_blank">Bootstrap admin template</a> from Bootstrapdash.com</span> *@
                    </div>
                </footer>
            </div>
        </div>
    </div>

    <script src="../../LayoutAdmin/assets/vendors/js/vendor.bundle.base.js"></script>
    <script src="../../LayoutAdmin/assets/js/off-canvas.js"></script>
    <script src="../../LayoutAdmin/assets/js/hoverable-collapse.js"></script>
    <script src="../../LayoutAdmin/assets/js/misc.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    @RenderSection("Scripts", required: false)
    
    <!-- Submenu Toggle Script -->
    <script>
        // Toggle submenu function - Global scope
        function toggleSubmenu(element) {
            // Prevent default and stop propagation
            if (event) {
                event.preventDefault();
                event.stopPropagation();
            }
            
            console.log('Toggle submenu clicked'); // Debug
            
            const parentItem = element.closest('.nav-item.has-submenu');
            if (!parentItem) {
                console.log('Parent item not found');
                return false;
            }
            
            const isActive = parentItem.classList.contains('active');
            console.log('Is active:', isActive);
            
            // Close all other submenus
            document.querySelectorAll('.nav-item.has-submenu.active').forEach(item => {
                if (item !== parentItem) {
                    item.classList.remove('active');
                    console.log('Closed other submenu');
                }
            });
            
            // Toggle current submenu
            if (isActive) {
                parentItem.classList.remove('active');
                console.log('Closed current submenu');
            } else {
                parentItem.classList.add('active');
                console.log('Opened current submenu');
            }
            
            return false; // Prevent default action
        }

        // Handle submenu item click
        function handleSubmenuItemClick(element, url, title) {
            // Prevent default
            if (event) {
                event.preventDefault();
                event.stopPropagation();
            }
            
            // Load page
            loadPage(url, title);
            
            // Update active states
            updateActiveMenuItem(url);
            
            return false;
        }

        // AJAX Navigation function
        function loadPage(url, title) {
            // Show loading indicator
            showLoading();
            
            // Update browser URL without reload
            if (history.pushState) {
                history.pushState(null, null, url);
            }
            
            // Update page title
            document.title = title + ' - Admin Panel';
            
            // Load content via AJAX
            fetch(url)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.text();
                })
                .then(html => {
                    console.log('Raw HTML response:', html.substring(0, 500)); // Debug
                    
                    // Extract main content from response
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    
                    // Try multiple selectors to find content
                    let mainContent = doc.querySelector('.main-panel .content-wrapper') ||
                                   doc.querySelector('.content-wrapper') ||
                                   doc.querySelector('.main-panel') ||
                                   doc.querySelector('main') ||
                                   doc.querySelector('.container-fluid');
                    
                    console.log('Found main content:', mainContent); // Debug
                    
                    if (mainContent) {
                        // Update content
                        const contentWrapper = document.querySelector('.main-panel .content-wrapper') ||
                                             document.querySelector('.content-wrapper') ||
                                             document.querySelector('.main-panel');
                        
                        if (contentWrapper) {
                            contentWrapper.innerHTML = mainContent.innerHTML;
                            console.log('Content updated successfully');
                            
                            // Execute JavaScript after content is loaded
                            executeScripts(mainContent);
                            
                            // Re-initialize common features after content is loaded
                            setTimeout(() => {
                                initializeCommonFeatures();
                                initializePageSpecificFeatures();
                            }, 100);
                        } else {
                            console.error('Could not find target content wrapper');
                        }
                        
                        // Update active menu item
                        updateActiveMenuItem(url);
                        
                        // Hide loading
                        hideLoading();
                        
                        console.log('Page loaded successfully:', title);
                    } else {
                        console.error('Could not find main content in response');
                        // Fallback: try to load the page normally
                        window.location.href = url;
                    }
                })
                .catch(error => {
                    console.error('Error loading page:', error);
                    hideLoading();
                    alert('Lỗi khi tải trang: ' + error.message);
                });
        }

        // Show loading indicator
        function showLoading() {
            const contentWrapper = document.querySelector('.main-panel .content-wrapper');
            if (contentWrapper) {
                contentWrapper.innerHTML = `
                    <div class="d-flex justify-content-center align-items-center" style="height: 400px;">
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-3 text-muted">Đang tải...</p>
                        </div>
                    </div>
                `;
            }
        }

        // Hide loading indicator
        function hideLoading() {
            const contentWrapper = document.querySelector('.main-panel .content-wrapper') ||
                                 document.querySelector('.content-wrapper') ||
                                 document.querySelector('.main-panel');
            
            if (contentWrapper) {
                // Remove loading spinner if it exists
                const loadingSpinner = contentWrapper.querySelector('.spinner-border');
                if (loadingSpinner) {
                    loadingSpinner.remove();
                }
                console.log('Loading indicator hidden');
            }
        }

        // Execute JavaScript from loaded content
        function executeScripts(contentElement) {
            const scripts = contentElement.querySelectorAll('script');
            scripts.forEach(script => {
                const newScript = document.createElement('script');
                
                // Copy script attributes
                Array.from(script.attributes).forEach(attr => {
                    newScript.setAttribute(attr.name, attr.value);
                });
                
                // Copy script content
                if (script.src) {
                    newScript.src = script.src;
                } else {
                    newScript.textContent = script.textContent;
                }
                
                // Append to head to execute
                document.head.appendChild(newScript);
                
                // Remove after execution to avoid duplicates
                setTimeout(() => {
                    if (newScript.parentNode) {
                        newScript.parentNode.removeChild(newScript);
                    }
                }, 100);
            });
            
            // Re-initialize common functionality after AJAX load
            setTimeout(() => {
                initializeCommonFeatures();
                initializePageSpecificFeatures();
            }, 200);
        }
        
        // Initialize page-specific features based on current page
        function initializePageSpecificFeatures() {
            const currentUrl = window.location.pathname;
            console.log('Initializing page-specific features for:', currentUrl);
            
            // Product Index page
            if (currentUrl.includes('/Admin/Product') || currentUrl.includes('/Product/Index')) {
                initializeProductIndexFeatures();
            }
            
            // TourDay Index page
            if (currentUrl.includes('/Admin/TourDay') || currentUrl.includes('/TourDay/Index')) {
                initializeTourDayIndexFeatures();
            }
            
            // Account Index page
            if (currentUrl.includes('/Admin/Account') || currentUrl.includes('/Account/Index')) {
                initializeAccountIndexFeatures();
            }
            
            // Add more page-specific initializations as needed
        }
        
        // Initialize Product Index page features
        function initializeProductIndexFeatures() {
            console.log('Initializing Product Index features');
            
            // Re-initialize search functionality
            const searchBtn = document.getElementById('searchBtn');
            const categoryFilter = document.getElementById('categoryFilter');
            const fromDate = document.getElementById('fromDate');
            const toDate = document.getElementById('toDate');
            const searchName = document.getElementById('searchName');
            
            if (searchBtn) {
                // Remove existing event listeners
                searchBtn.removeEventListener('click', performProductSearch);
                // Add new event listener
                searchBtn.addEventListener('click', performProductSearch);
            }
            
            if (categoryFilter) {
                categoryFilter.removeEventListener('change', performProductSearch);
                categoryFilter.addEventListener('change', performProductSearch);
            }
            
            if (fromDate) {
                fromDate.removeEventListener('change', performProductSearch);
                fromDate.addEventListener('change', performProductSearch);
            }
            
            if (toDate) {
                toDate.removeEventListener('change', performProductSearch);
                toDate.addEventListener('change', performProductSearch);
            }
            
            if (searchName) {
                searchName.removeEventListener('keypress', handleProductSearchKeypress);
                searchName.addEventListener('keypress', handleProductSearchKeypress);
            }
            
            // Re-initialize tooltips
            initializeTooltips();
        }
        
        // Product search function
        function performProductSearch() {
            const searchName = document.getElementById('searchName')?.value || '';
            const categoryId = document.getElementById('categoryFilter')?.value || '';
            const fromDate = document.getElementById('fromDate')?.value || '';
            const toDate = document.getElementById('toDate')?.value || '';

            const params = new URLSearchParams();
            if (searchName) params.append('searchName', searchName);
            if (categoryId) params.append('categoryId', categoryId);
            if (fromDate) params.append('fromDate', fromDate);
            if (toDate) params.append('toDate', toDate);

            // Show loading
            const container = document.getElementById('productTableContainer');
            if (container) {
                container.innerHTML = '<div class="text-center p-4"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';

                // Get current URL and add parameters
                const currentUrl = window.location.pathname;
                const searchUrl = currentUrl + '?' + params.toString();
                
                fetch(searchUrl)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.text();
                    })
                    .then(html => {
                        // Parse the response to extract only the table content
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const tableContainer = doc.querySelector('#productTableContainer');
                        
                        if (tableContainer) {
                            container.innerHTML = tableContainer.innerHTML;
                            
                            // Re-initialize tooltips
                            initializeTooltips();
                        } else {
                            container.innerHTML = '<div class="alert alert-warning">Không tìm thấy kết quả nào</div>';
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        container.innerHTML = '<div class="alert alert-danger">Có lỗi xảy ra khi tìm kiếm</div>';
                    });
            }
        }
        
        // Handle product search keypress
        function handleProductSearchKeypress(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                performProductSearch();
            }
        }
        
        // Initialize TourDay Index page features
        function initializeTourDayIndexFeatures() {
            console.log('Initializing TourDay Index features');
            
            // Re-initialize search functionality
            const searchBtn = document.getElementById('searchBtn');
            const searchName = document.getElementById('searchName');
            const categoryFilter = document.getElementById('categoryFilter');
            const productFilter = document.getElementById('productFilter');
            const dayNumberFilter = document.getElementById('dayNumberFilter');
            
            if (searchBtn) {
                searchBtn.removeEventListener('click', performTourDaySearch);
                searchBtn.addEventListener('click', performTourDaySearch);
            }
            
            if (searchName) {
                searchName.removeEventListener('keypress', handleTourDaySearchKeypress);
                searchName.addEventListener('keypress', handleTourDaySearchKeypress);
            }
            
            if (categoryFilter) {
                categoryFilter.removeEventListener('change', performTourDaySearch);
                categoryFilter.addEventListener('change', performTourDaySearch);
            }
            
            if (productFilter) {
                productFilter.removeEventListener('change', performTourDaySearch);
                productFilter.addEventListener('change', performTourDaySearch);
            }
            
            if (dayNumberFilter) {
                dayNumberFilter.removeEventListener('keypress', handleTourDaySearchKeypress);
                dayNumberFilter.addEventListener('keypress', handleTourDaySearchKeypress);
            }
            
            initializeTooltips();
        }
        
        // TourDay search function
        function performTourDaySearch() {
            const searchName = document.getElementById('searchName')?.value || '';
            const categoryId = document.getElementById('categoryFilter')?.value || '';
            const productId = document.getElementById('productFilter')?.value || '';
            const dayNumber = document.getElementById('dayNumberFilter')?.value || '';
            
            const params = new URLSearchParams();
            if (searchName) params.append('searchName', searchName);
            if (categoryId) params.append('categoryId', categoryId);
            if (productId) params.append('productId', productId);
            if (dayNumber) params.append('dayNumber', dayNumber);

            const container = document.getElementById('tourDayTableContainer');
            if (container) {
                container.innerHTML = '<div class="text-center p-4"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';

                const currentUrl = window.location.pathname;
                const searchUrl = currentUrl + '?' + params.toString();
                
                fetch(searchUrl)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.text();
                    })
                    .then(html => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const tableContainer = doc.querySelector('#tourDayTableContainer');
                        
                        if (tableContainer) {
