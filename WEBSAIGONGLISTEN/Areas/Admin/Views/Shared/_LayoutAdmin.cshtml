                    @if (User.IsInRole("Admin"))
                    {
                        <!-- Quản lý hệ thống -->
                        <li class="nav-item has-submenu">
                            <a class="nav-link" href="#" onclick="toggleSubmenu(this)">
                                <i class="mdi mdi-account-group menu-icon"></i>
                                <span class="menu-title">Quản lý hệ thống</span>
                                <i class="mdi mdi-chevron-down submenu-arrow"></i>
                            </a>
                            <ul class="submenu">
                                <li class="nav-item">
                                    <a class="nav-link" href="javascript:void(0)" onclick="return handleSubmenuItemClick(this, '@Url.Action("Index", "Account")', 'Người dùng')">
                                        <i class="mdi mdi-account-group menu-icon"></i>
                                        <span class="menu-title">Người dùng</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="javascript:void(0)" onclick="return handleSubmenuItemClick(this, '@Url.Action("Index", "RecordVideo", new { area = "Admin" })', 'Record Video')">
                                        <i class="mdi mdi-video menu-icon"></i>
                                        <span class="menu-title">Record Video</span>
