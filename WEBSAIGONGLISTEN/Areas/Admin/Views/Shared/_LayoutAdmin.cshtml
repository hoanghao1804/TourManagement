                                <i class="mdi mdi-package-variant menu-icon"></i>
                                <span class="menu-title">Quản lý sản phẩm</span>
                                <i class="mdi mdi-chevron-down submenu-arrow"></i>
                            </a>
                            <ul class="submenu">
                                <li class="nav-item">
                                    <a class="nav-link" href="javascript:void(0)" onclick="return handleSubmenuItemClick(this, '@Url.Action("Index", "Product")', 'Danh sách sản phẩm')">
                                        <i class="mdi mdi-package-variant menu-icon"></i>
                                        <span class="menu-title">Danh sách sản phẩm</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="javascript:void(0)" onclick="return handleSubmenuItemClick(this, '@Url.Action("Add", "Product")', 'Thêm sản phẩm')">
