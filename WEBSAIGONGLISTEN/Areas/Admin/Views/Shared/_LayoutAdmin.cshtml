        // Update active menu item
        function updateActiveMenuItem(url) {
            // Remove active class from all menu items
            document.querySelectorAll('.sidebar .nav-item').forEach(item => {
                item.classList.remove('active');
            });
            
            // Find and activate the matching menu item
            const menuLinks = document.querySelectorAll('.sidebar .nav-link');
            menuLinks.forEach(link => {
                if (link.getAttribute('href') === url || link.getAttribute('onclick')?.includes(url)) {
                    const navItem = link.closest('.nav-item');
                    if (navItem) {
                        navItem.classList.add('active');
                        
                        // If it's a submenu item, also open the parent submenu
                        const parentSubmenu = navItem.closest('.nav-item.has-submenu');
                        if (parentSubmenu) {
                            parentSubmenu.classList.add('active');
                        }
                    }
                }
            });
        }
        
        // Load page with fallback to normal navigation
        function loadPageWithFallback(url, title, element) {
            event.preventDefault();
            
            try {
                loadPage(url, title);
            } catch (error) {
                console.error('AJAX failed, falling back to normal navigation:', error);
                window.location.href = url;
            }
            
            return false;
        }

        // Make functions globally available
        window.toggleSubmenu = toggleSubmenu;
        window.loadPage = loadPage;
        window.loadPageWithFallback = loadPageWithFallback;
        window.handleSubmenuItemClick = handleSubmenuItemClick;
