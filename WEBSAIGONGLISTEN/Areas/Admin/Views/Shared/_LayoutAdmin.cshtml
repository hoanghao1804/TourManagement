                            <a class="nav-link" href="#" onclick="toggleSubmenu(this)">
                                <i class="mdi mdi-bell-outline menu-icon"></i>
                                <span class="menu-title">Giao dịch và thông báo</span>
                                <i class="mdi mdi-chevron-down submenu-arrow"></i>
                            </a>
                            <ul class="submenu">
                                <li class="nav-item">
                                    <a class="nav-link" href="javascript:void(0)" onclick="return handleSubmenuItemClick(this, '@Url.Action("Index", "History")', 'Lịch sử giao dịch')">
                                        <i class="mdi mdi-history menu-icon"></i>
                                        <span class="menu-title">Lịch sử giao dịch</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="javascript:void(0)" onclick="return handleSubmenuItemClick(this, '@Url.Action("Index", "ThongBao", new { area = "Admin" })', 'Thông báo')">
                                        <i class="mdi mdi-bell-outline menu-icon"></i>
                                        <span class="menu-title">Thông báo</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="javascript:void(0)" onclick="return handleSubmenuItemClick(this, '@Url.Action("Create", "ThongBao", new { area = "Admin" })', 'Tạo thông báo')">
                                        <i class="mdi mdi-bell-plus menu-icon"></i>
