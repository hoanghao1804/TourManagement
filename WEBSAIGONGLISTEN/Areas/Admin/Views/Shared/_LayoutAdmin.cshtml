            menu.style.transform = 'none';
            menu.style.transition = 'none';
            menu.style.animation = 'none';
            menu.style.borderTop = 'none';
        });
        
        // Fix dropdown item text colors
        const dropdownItems = document.querySelectorAll('.dropdown-menu .dropdown-item, .navbar-dropdown .dropdown-item');
        dropdownItems.forEach(item => {
            item.style.color = '#333';
            item.style.background = 'transparent';
            item.style.transition = 'none';
            item.style.animation = 'none';
            
            // Add hover event listener
            item.addEventListener('mouseenter', function() {
                this.style.color = '#333';
                this.style.background = '#f8f9fa';
            });
            
            item.addEventListener('mouseleave', function() {
                this.style.color = '#333';
                this.style.background = 'transparent';
            });
        });
        
        // Force fix sidebar alignment
        const sidebarLinks = document.querySelectorAll('.sidebar .nav-item .nav-link');
        sidebarLinks.forEach(link => {
            link.style.justifyContent = 'flex-start';
            link.style.textAlign = 'left';
            link.style.margin = '2px 0';
            link.style.padding = '12px 20px';
            link.style.display = 'flex';
            link.style.alignItems = 'center';
            link.style.width = '100%';
            link.style.boxSizing = 'border-box';
        });
        
        // Force show all menu icons
        const menuIcons = document.querySelectorAll('.sidebar .nav-item .nav-link .menu-icon');
        menuIcons.forEach(icon => {
            icon.style.display = 'inline-block';
            icon.style.fontSize = '1.2rem';
            icon.style.color = '#ecf0f1';
            icon.style.marginRight = '10px';
            icon.style.width = '20px';
            icon.style.textAlign = 'center';
            icon.style.flexShrink = '0';
        });
        
        // Fix submenu alignment
        const submenuLinks = document.querySelectorAll('.sidebar .nav-item.has-submenu .submenu .nav-link');
        submenuLinks.forEach(link => {
            link.style.justifyContent = 'flex-start';
            link.style.textAlign = 'left';
            link.style.margin = '2px 0';
            link.style.padding = '8px 20px';
            link.style.display = 'flex';
            link.style.alignItems = 'center';
            link.style.marginLeft = '0';
            link.style.marginRight = '0';
        });
        
        // Remove duplicate event listeners to prevent flickering
        const submenuToggles = document.querySelectorAll('.sidebar .nav-item.has-submenu > .nav-link');
        submenuToggles.forEach(toggle => {
            // Remove any existing event listeners
            toggle.removeEventListener('click', toggleSubmenu);
            // Don't add new event listeners - let onclick handle it
        });
        
        // Target all nav-links
        const sidebarLinks = document.querySelectorAll('.sidebar .nav .nav-item .nav-link');
        sidebarLinks.forEach(link => {
            link.style.background = 'transparent';
            link.style.backgroundColor = 'transparent';
            link.style.backgroundImage = 'none';
            link.style.color = '#ecf0f1';
            
            // Add click event to highlight active tab
            link.addEventListener('click', function() {
                // Remove active class from all nav-items
                const allNavItems = document.querySelectorAll('.sidebar .nav .nav-item');
                allNavItems.forEach(item => {
                    item.classList.remove('active');
                });
                
                // Add active class to clicked item's parent
                const parentNavItem = this.closest('.nav-item');
                if (parentNavItem) {
                    parentNavItem.classList.add('active');
                }
            });
        });
        
        // Force override any existing styles for non-active items
        const allNavItems = document.querySelectorAll('.sidebar .nav .nav-item:not(.active)');
        allNavItems.forEach(item => {
            item.style.background = 'transparent';
            item.style.backgroundColor = 'transparent';
            item.style.backgroundImage = 'none';
        });
    });
</script>

