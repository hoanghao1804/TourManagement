        // Account search function
        function performAccountSearch() {
            const searchName = document.getElementById('searchName')?.value || '';
            const searchAddress = document.getElementById('searchAddress')?.value || '';
            const roleFilter = document.getElementById('roleFilter')?.value || '';
            
            const params = new URLSearchParams();
            if (searchName) params.append('searchName', searchName);
            if (searchAddress) params.append('searchAddress', searchAddress);
            if (roleFilter) params.append('roleFilter', roleFilter);

            const container = document.getElementById('userTableContainer');
            if (container) {
                container.innerHTML = '<div class="text-center p-4"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';

                const currentUrl = window.location.pathname;
                const searchUrl = currentUrl + '?' + params.toString();
                
                fetch(searchUrl)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.text();
                    })
                    .then(html => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const tableContainer = doc.querySelector('#userTableContainer');
                        
                        if (tableContainer) {
                            container.innerHTML = tableContainer.innerHTML;
                            initializeTooltips();
                        } else {
                            container.innerHTML = '<div class="alert alert-warning">Không tìm thấy kết quả nào</div>';
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        container.innerHTML = '<div class="alert alert-danger">Có lỗi xảy ra khi tìm kiếm</div>';
                    });
            }
        }
        
