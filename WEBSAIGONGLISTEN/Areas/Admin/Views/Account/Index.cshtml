@model List<ApplicationUser>

<style>
    .table {
        width: 100% !important;
        table-layout: fixed !important;
        margin: 0 !important;
    }
    
    #userTableContainer {
        width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
    }
    
    .table-responsive {
        width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
    }
    
    .table td {
        vertical-align: middle !important;
        word-wrap: break-word !important;
        overflow: hidden !important;
    }
    
    .table th:nth-child(1), .table td:nth-child(1) { 
        width: 15% !important; 
        max-width: 150px !important;
    } /* Tên */
    
    .table th:nth-child(2), .table td:nth-child(2) { 
        width: 20% !important; 
        max-width: 200px !important;
    } /* Email */
    
    .table th:nth-child(3), .table td:nth-child(3) { 
        width: 20% !important; 
        max-width: 200px !important;
    } /* Địa chỉ */
    
    .table th:nth-child(4), .table td:nth-child(4) { 
        width: 10% !important; 
        max-width: 100px !important;
    } /* Tuổi */
    
    .table th:nth-child(5), .table td:nth-child(5) { 
        width: 15% !important; 
        max-width: 150px !important;
    } /* Vai trò */
    
    .table th:nth-child(6), .table td:nth-child(6) { 
        width: 20% !important; 
        max-width: 200px !important;
    } /* Thao tác */
</style>

<h1 class="mb-4">Quản Lý Người Dùng</h1>

<!-- Filter Section -->
<div class="card mb-4 shadow">
    <div class="card-body">
        <form id="filterForm">
            <div class="row g-2">
                <!-- Tìm kiếm theo tên -->
                <div class="col-md-3">
                    <label for="searchName" class="form-label fw-bold">
                        <i class="fas fa-search me-1"></i>
                        Tìm kiếm theo tên
                    </label>
                    <input type="text" 
                           class="form-control" 
                           id="searchName" 
                           name="searchName" 
                           value="@(ViewBag.SearchName ?? "")"
                           placeholder="Nhập tên người dùng...">
                </div>

                <!-- Tìm kiếm theo địa chỉ -->
                <div class="col-md-3">
                    <label for="searchAddress" class="form-label fw-bold">
                        <i class="fas fa-map-marker-alt me-1"></i>
                        Tìm kiếm theo địa chỉ
                    </label>
                    <input type="text" 
                           class="form-control" 
                           id="searchAddress" 
                           name="searchAddress" 
                           value="@(ViewBag.SearchAddress ?? "")"
                           placeholder="Nhập địa chỉ...">
                </div>

                <!-- Filter theo vai trò -->
                <div class="col-md-3">
                    <label for="roleFilter" class="form-label fw-bold">
                        <i class="fas fa-user-tag me-1"></i>
                        Vai trò
                    </label>
                    <select class="form-select" id="roleFilter" name="roleFilter">
                        <option value="">Tất cả vai trò</option>
                        @if (ViewBag.AllRoles != null)
                        {
                            @foreach (var role in ViewBag.AllRoles)
                            {
                                var isSelected = ViewBag.SelectedRole?.ToString() == role ? "selected" : "";
                                <option value="@role" selected="@isSelected">
                                    @role
                                </option>
                            }
                        }
                    </select>
                </div>

                <!-- Nút tìm kiếm -->
                <div class="col-md-3 d-flex align-items-end">
                    <button type="button" id="searchBtn" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i>
                        Tìm kiếm
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="userTableContainer">
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th scope="col">Tên</th>
                    <th scope="col">Email</th>
                    <th scope="col">Địa chỉ</th>
                    <th scope="col">Tuổi</th>
                    <th scope="col">Vai trò</th>
                    <th scope="col">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewData["UsersWithRoles"] != null)
                {
                    var usersWithRoles = (List<(ApplicationUser User, string Role)>)ViewData["UsersWithRoles"];
                    @foreach (var (user, role) in usersWithRoles)
                    {
                        <tr>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@(user.Address ?? "Chưa cập nhật")</td>
                            <td>@(user.Age?.ToString() ?? "Chưa cập nhật")</td>
                            <td>
                                <span class="badge bg-info">@role</span>
                            </td>
                            <td>
                                <a class="btn btn-primary btn-sm" asp-area="Admin" asp-controller="Account" asp-action="ChangeRole" asp-route-userId="@user.Id">Thay đổi vai trò</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">Không có người dùng nào để hiển thị</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Hiển thị phân trang -->
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center">
        @for (int i = 1; i <= (int)ViewData["TotalPages"]; i++)
        {
            <li class="page-item @(i == (int)ViewData["CurrentPage"] ? "active" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
            </li>
        }
    </ul>
</nav>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // AJAX search function
            function performSearch() {
                const searchName = document.getElementById('searchName').value;
                const searchAddress = document.getElementById('searchAddress').value;
                const roleFilter = document.getElementById('roleFilter').value;

                const params = new URLSearchParams();
                if (searchName) params.append('searchName', searchName);
                if (searchAddress) params.append('searchAddress', searchAddress);
                if (roleFilter) params.append('roleFilter', roleFilter);

                // Show loading
                document.getElementById('userTableContainer').innerHTML = '<div class="text-center p-4"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';

                fetch('@Url.Action("Index")?' + params.toString())
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.text();
                    })
                    .then(html => {
                        // Parse the response to extract only the table content
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const tableContainer = doc.querySelector('#userTableContainer');
                        
                        if (tableContainer) {
                            document.getElementById('userTableContainer').innerHTML = tableContainer.innerHTML;
                        } else {
                            document.getElementById('userTableContainer').innerHTML = '<div class="alert alert-warning">Không tìm thấy kết quả nào</div>';
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        document.getElementById('userTableContainer').innerHTML = '<div class="alert alert-danger">Có lỗi xảy ra khi tìm kiếm</div>';
                    });
            }

            // Search button click
            document.getElementById('searchBtn').addEventListener('click', performSearch);

            // Auto-search when select changes
            document.getElementById('roleFilter').addEventListener('change', performSearch);

            // Search with Enter key
            document.getElementById('searchName').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    performSearch();
                }
            });

            document.getElementById('searchAddress').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    performSearch();
                }
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
