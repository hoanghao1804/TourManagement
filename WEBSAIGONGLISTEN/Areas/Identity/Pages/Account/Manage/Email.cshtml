@page
@model EmailModel
@{
    ViewData["Title"] = "Quản lý Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/account-manage.css" />

<div class="container mt-4">
    <div class="row">
        <!-- Left Sidebar Navigation -->
        <div class="col-md-3">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-cog me-2"></i>Cài đặt tài khoản</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/Identity/Account/Manage" class="list-group-item list-group-item-action">
                        <i class="fas fa-user me-2"></i>Thông tin cá nhân
                    </a>
                    <a href="/Identity/Account/Manage/Email" class="list-group-item list-group-item-action active">
                        <i class="fas fa-envelope me-2"></i>Email
                    </a>
                    <a href="/Identity/Account/Manage/ChangePassword" class="list-group-item list-group-item-action">
                        <i class="fas fa-key me-2"></i>Mật khẩu
                    </a>
                    <a href="/Identity/Account/Manage/ExternalLogins" class="list-group-item list-group-item-action">
                        <i class="fas fa-external-link-alt me-2"></i>Đăng nhập bên ngoài
                    </a>
                     <a href="/Identity/Account/Manage/TwoFactorAuthentication" class="list-group-item list-group-item-action">
                        <i class="fas fa-shield-alt me-2"></i>Xác thực 2 lớp
                    </a>
                    <a href="/Identity/Account/Manage/PersonalData" class="list-group-item list-group-item-action">
                        <i class="fas fa-download me-2"></i>Tải dữ liệu
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <!-- Status Message -->
            <partial name="_StatusMessage" model="Model.StatusMessage" />

            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0"><i class="fas fa-envelope me-2"></i>Quản lý Email</h4>
                    <small class="text-muted">Cập nhật và xác thực địa chỉ email của bạn</small>
                </div>
                <div class="card-body">
                    <form id="email-form" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger" style="display: none;"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label">
                                <i class="fas fa-envelope me-2 text-primary"></i>Email hiện tại
                            </label>
                            @if (Model.IsEmailConfirmed)
                            {
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-envelope text-muted"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control" disabled />
                                    <span class="input-group-text text-success">
                                        <i class="fas fa-check-circle"></i>
                                    </span>
                                </div>
                                <small class="form-text text-success">
                                    <i class="fas fa-check-circle me-1"></i>Email đã được xác thực
                                </small>
                            }
                            else
                            {
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-envelope text-muted"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control" disabled />
                                    <span class="input-group-text text-warning">
                                        <i class="fas fa-exclamation-triangle"></i>
                                    </span>
                                </div>
                                <button id="email-verification" type="submit" asp-page-handler="SendVerificationEmail" class="btn btn-outline-warning btn-sm mt-2">
                                    <i class="fas fa-paper-plane me-2"></i>Gửi email xác thực
                                </button>
                                <small class="form-text text-warning d-block mt-1">
                                    <i class="fas fa-exclamation-triangle me-1"></i>Email chưa được xác thực
                                </small>
                            }
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.NewEmail" class="form-label">
                                <i class="fas fa-envelope-plus me-2 text-primary"></i>Email mới
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="fas fa-envelope text-muted"></i>
                                </span>
                                <input asp-for="Input.NewEmail" class="form-control" autocomplete="email" aria-required="true" placeholder="Nhập email mới của bạn" />
                            </div>
                            <span asp-validation-for="Input.NewEmail" class="text-danger"></span>
                            <small class="form-text text-muted">Nhập địa chỉ email mới để thay đổi</small>
                        </div>

                        <div class="d-flex gap-2">
                            <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Thay đổi email
                            </button>
                            <a href="/Identity/Account/Manage" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Show validation summary if it has content
        $(document).ready(function() {
            var validationSummary = $('.alert.alert-danger');
            if (validationSummary.text().trim() !== '') {
                validationSummary.show();
            }
        });
    </script>
}
