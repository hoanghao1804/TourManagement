@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Thay đổi mật khẩu";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/account-manage.css" />

<div class="container mt-4">
    <div class="row">
        <!-- Left Sidebar Navigation -->
        <div class="col-md-3">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-cog me-2"></i>Cài đặt tài khoản</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/Identity/Account/Manage" class="list-group-item list-group-item-action">
                        <i class="fas fa-user me-2"></i>Thông tin cá nhân
                    </a>
                    <a href="/Identity/Account/Manage/Email" class="list-group-item list-group-item-action">
                        <i class="fas fa-envelope me-2"></i>Email
                    </a>
                    <a href="/Identity/Account/Manage/ChangePassword" class="list-group-item list-group-item-action active">
                        <i class="fas fa-key me-2"></i>Mật khẩu
                    </a>
                    <a href="/Identity/Account/Manage/ExternalLogins" class="list-group-item list-group-item-action">
                        <i class="fas fa-external-link-alt me-2"></i>Đăng nhập bên ngoài
                    </a>
                    <a href="/Identity/Account/Manage/TwoFactorAuthentication" class="list-group-item list-group-item-action">
                        <i class="fas fa-shield-alt me-2"></i>Xác thực 2 lớp
                    </a>
                    <a href="/Identity/Account/Manage/PersonalData" class="list-group-item list-group-item-action">
                        <i class="fas fa-download me-2"></i>Tải dữ liệu
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <!-- Status Message -->
            <partial name="_StatusMessage" for="StatusMessage" />

            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0"><i class="fas fa-key me-2"></i>Thay đổi mật khẩu</h4>
                    <small class="text-muted">Cập nhật mật khẩu để bảo mật tài khoản</small>
                </div>
                <div class="card-body">
                    <form id="change-password-form" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger" style="display: none;"></div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.OldPassword" class="form-label">
                                        <i class="fas fa-lock me-2 text-primary"></i>Mật khẩu hiện tại
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="fas fa-key text-muted"></i>
                                        </span>
                                        <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Nhập mật khẩu hiện tại" />
                                    </div>
                                    <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                                    <small class="form-text text-muted">Nhập mật khẩu hiện tại của bạn</small>
                                </div>
                                
                                <div class="mb-3">
                                    <label asp-for="Input.NewPassword" class="form-label">
                                        <i class="fas fa-lock me-2 text-primary"></i>Mật khẩu mới
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="fas fa-key text-muted"></i>
                                        </span>
                                        <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Nhập mật khẩu mới" />
                                    </div>
                                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                                    <small class="form-text text-muted">Mật khẩu phải có ít nhất 6 ký tự</small>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.ConfirmPassword" class="form-label">
                                        <i class="fas fa-lock me-2 text-primary"></i>Xác nhận mật khẩu mới
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="fas fa-key text-muted"></i>
                                        </span>
                                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Nhập lại mật khẩu mới" />
                                    </div>
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                                    <small class="form-text text-muted">Nhập lại mật khẩu mới để xác nhận</small>
                                </div>
                                
                                <div class="password-tips">
                                    <h6><i class="fas fa-info-circle me-2"></i>Mẹo bảo mật</h6>
                                    <ul class="list-unstyled">
                                        <li><i class="fas fa-check text-success me-2"></i>Sử dụng ít nhất 8 ký tự</li>
                                        <li><i class="fas fa-check text-success me-2"></i>Kết hợp chữ hoa, chữ thường</li>
                                        <li><i class="fas fa-check text-success me-2"></i>Bao gồm số và ký tự đặc biệt</li>
                                        <li><i class="fas fa-check text-success me-2"></i>Tránh thông tin cá nhân</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Cập nhật mật khẩu
                            </button>
                            <a href="/Identity/Account/Manage" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Show validation summary if it has content
        $(document).ready(function() {
            var validationSummary = $('.alert.alert-danger');
            if (validationSummary.text().trim() !== '') {
                validationSummary.show();
            }
        });
    </script>
}