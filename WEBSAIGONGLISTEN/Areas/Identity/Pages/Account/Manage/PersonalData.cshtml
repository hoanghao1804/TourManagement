@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Dữ liệu cá nhân";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/account-manage.css" />

<div class="container mt-4">
    <div class="row">
        <!-- Left Sidebar Navigation -->
        <div class="col-md-3">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-cog me-2"></i>Cài đặt tài khoản</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/Identity/Account/Manage" class="list-group-item list-group-item-action">
                        <i class="fas fa-user me-2"></i>Thông tin cá nhân
                    </a>
                    <a href="/Identity/Account/Manage/Email" class="list-group-item list-group-item-action">
                        <i class="fas fa-envelope me-2"></i>Email
                    </a>
                    <a href="/Identity/Account/Manage/ChangePassword" class="list-group-item list-group-item-action">
                        <i class="fas fa-key me-2"></i>Mật khẩu
                    </a>
                    <a href="/Identity/Account/Manage/ExternalLogins" class="list-group-item list-group-item-action">
                        <i class="fas fa-external-link-alt me-2"></i>Đăng nhập bên ngoài
                    </a>
                     <a href="/Identity/Account/Manage/TwoFactorAuthentication" class="list-group-item list-group-item-action">
                        <i class="fas fa-shield-alt me-2"></i>Xác thực 2 lớp
                    </a>
                    <a href="/Identity/Account/Manage/PersonalData" class="list-group-item list-group-item-action">
                        <i class="fas fa-download me-2"></i>Tải dữ liệu
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0"><i class="fas fa-download me-2"></i>Dữ liệu cá nhân</h4>
                    <small class="text-muted">Quản lý và tải xuống dữ liệu cá nhân của bạn</small>
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-4">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Thông tin về dữ liệu cá nhân</strong>
                        <p class="mb-0">Tài khoản của bạn chứa dữ liệu cá nhân mà bạn đã cung cấp cho chúng tôi. Trang này cho phép bạn tải xuống hoặc xóa dữ liệu đó.</p>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="card h-100 border-success">
                                <div class="card-body text-center">
                                    <i class="fas fa-download text-success mb-3" style="font-size: 3rem;"></i>
                                    <h5>Tải xuống dữ liệu</h5>
                                    <p class="text-muted">Tải xuống tất cả dữ liệu cá nhân của bạn trong một file JSON</p>
                                    <form id="download-data" asp-page="DownloadPersonalData" method="post" class="d-inline">
                                        <button class="btn btn-success" type="submit">
                                            <i class="fas fa-download me-2"></i>Tải xuống dữ liệu
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="card h-100 border-danger">
                                <div class="card-body text-center">
                                    <i class="fas fa-trash text-danger mb-3" style="font-size: 3rem;"></i>
                                    <h5>Xóa tài khoản</h5>
                                    <p class="text-muted">Xóa vĩnh viễn tài khoản và tất cả dữ liệu cá nhân</p>
                                    <a id="delete" role="button" asp-page="DeletePersonalData" class="btn btn-danger">
                                        <i class="fas fa-trash me-2"></i>Xóa tài khoản
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning mt-4">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Cảnh báo quan trọng</strong>
                        <p class="mb-0">
                            <strong>Việc xóa dữ liệu sẽ xóa vĩnh viễn tài khoản của bạn và không thể khôi phục được.</strong>
                            Hãy chắc chắn rằng bạn muốn thực hiện hành động này trước khi tiếp tục.
                        </p>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <a href="/Identity/Account/Manage" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
